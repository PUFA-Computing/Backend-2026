# ============================================================
# Dockerfile.dev — Development only (hot-reload via Air)
# Usage: docker compose -f docker-compose.dev.yml up --build
# ============================================================
FROM golang:1.24-alpine

# Install build tools + air for hot-reload
RUN apk add --no-cache git gcc musl-dev curl && \
    go install github.com/air-verse/air@latest

WORKDIR /app

# Pre-download dependencies (cache layer)
COPY go.mod go.sum ./
RUN go mod download

# Source code will be mounted as a volume at runtime
# so we do NOT COPY . . here

EXPOSE 8080

# Air will watch for changes and recompile automatically
CMD ["air", "-c", ".air.toml"]
